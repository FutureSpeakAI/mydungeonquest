modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
MUSIC_PROVIDER = "elevenlabs"
PAINT_PROVIDER = "openai"
SFX_PROVIDER = "elevenlabs"
SPEAK_PROVIDER = "elevenlabs"
DM_MODEL = "claude-sonnet-5"
DM_MODEL_GENESIS = "claude-sonnet-5"
DM_MODEL_UTILITY = "claude-haiku-4-5-20251001"

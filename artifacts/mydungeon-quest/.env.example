NODE_ENV=development
PORT=3001
APP_ORIGIN=http://localhost:5173
DM_PROVIDER=auto
DM_MODEL=claude-sonnet-4-6
DM_MODEL_UTILITY=claude-3-5-haiku-latest
DM_MODEL_GENESIS=claude-sonnet-4-6
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
REPLICATE_API_TOKEN=
RUNWAY_API_KEY=
ELEVENLABS_API_KEY=
PAINT_PROVIDER=auto
VIDEO_PROVIDER=auto            # openai (Sora) | replicate | mock
VIDEO_MODEL_OPENAI=sora-2
REPLICATE_VIDEO_MODEL=         # e.g. a text-to-video model slug on Replicate
REPLICATE_VIDEO_IMAGE_PARAM=image  # the model input field for a reference frame
SPEAK_PROVIDER=auto
MUSIC_PROVIDER=auto
SFX_PROVIDER=auto
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_DM_MAX=20
RATE_LIMIT_MEDIA_MAX=30
MAX_REQUEST_BYTES=2097152
MAX_PDF_HTML_BYTES=104857600
MEDIA_IMAGE_CAP=80
MEDIA_VIDEO_CAP=16
MEDIA_MUSIC_CAP=8
MOCK_SEED=mydungeon-quest
